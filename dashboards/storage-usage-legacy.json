        "code": {"language": "html", "showLineNumbers": false, "showMiniMap": false},
        "content": "<div id=\"ksdg-storage-root\" style=\"font:14px -apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;color:#d8d9da;padding:4px 8px\"><div id=\"ksdg-storage-summary\" style=\"color:#888;margin-bottom:6px;font-size:13px\">Loading…</div><div id=\"ksdg-storage-refresh\" style=\"color:#555;margin-bottom:14px;font-size:11px;font-family:monospace\"></div><div id=\"ksdg-storage-disks\"></div></div><script>(function(){var ROOT=document.getElementById('ksdg-storage-root');if(!ROOT)return;if(ROOT.dataset.booted){if(window.__KSDG_LOAD)window.__KSDG_LOAD();return;}ROOT.dataset.booted='1';var PREFIX='nsd';var DS_UID='prometheus';var CATS=[[\"containerd-images\",\"#3B82F6\",\"Containerd images\"],[\"longhorn\",\"#10B981\",\"Longhorn data\"],[\"pod-ephemeral\",\"#A855F7\",\"Pod ephemeral\"],[\"local-path-pvc\",\"#64748B\",\"Local-path PVCs\"],[\"local-path-cache\",\"#22D3EE\",\"Local-path caches\"],[\"buildkit\",\"#FBBF24\",\"BuildKit\"],[\"dockerd\",\"#F97316\",\"Dockerd\"],[\"fscache\",\"#B877D9\",\"NFS/SMB cache\"],[\"apt-cache\",\"#73BF69\",\"APT cache\"],[\"journald\",\"#F59E0B\",\"Journald logs\"],[\"snap\",\"#FFB357\",\"Snap\"],[\"home\",\"#EF4444\",\"Home\"],[\"crash-dumps\",\"#FF7383\",\"Kernel crash dumps\"],[\"swap\",\"#6B7280\",\"Swap\"]];var FREE_COLOR='#3a3f46';var OTHER_COLOR='#9CA3AF';var loadCount=0;function fmt(n){if(n==null)return '\\u2014';n=+n;var u=['B','KB','MB','GB','TB'],i=0;while(Math.abs(n)>=1024&&i<u.length-1){n/=1024;i++;}return n.toFixed(n<10?1:0)+' '+u[i];}function q(p){return fetch('/api/datasources/proxy/uid/'+DS_UID+'/api/v1/query?query='+encodeURIComponent(p),{credentials:'same-origin'}).then(function(r){return r.json();}).then(function(j){return (j.data&&j.data.result)||[];}).catch(function(){return [];});}function esc(s){return String(s).replace(/[&<>\"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#39;'}[c];});}function render(size,used,cats){var keys=Object.keys(size).sort(function(a,b){return a<b?-1:a>b?1:0;});var html='';var totalSize=0,totalUsed=0;keys.forEach(function(k){totalSize+=size[k];totalUsed+=(used[k]||0);});var sumEl=document.getElementById('ksdg-storage-summary');if(sumEl)sumEl.innerHTML=fmt(totalUsed)+' of '+fmt(totalSize)+' used across '+keys.length+' disks ('+(totalSize?Math.round(100*totalUsed/totalSize):0)+'%)';var lastNode=null;keys.forEach(function(k){var parts=k.split('|'),node=parts[0],mp=parts[1];var sz=size[k],u=used[k]||0,c=cats[k]||{};var seenKnown=0;CATS.forEach(function(x){seenKnown+=(c[x[0]]||0);});var residual=Math.max(0,u-seenKnown);var freeB=Math.max(0,sz-u);var segs='';CATS.forEach(function(x){var v=c[x[0]]||0;if(v<=0)return;var pct=100*v/Math.max(sz,1);segs+='<div style=\"height:100%;background:'+x[1]+';width:'+pct.toFixed(3)+'%;border-right:1px solid rgba(0,0,0,0.25)\" title=\"'+esc(x[2])+': '+fmt(v)+' ('+pct.toFixed(1)+'%)\"></div>';});if(residual>0){var pct=100*residual/Math.max(sz,1);segs+='<div style=\"height:100%;background:'+OTHER_COLOR+';width:'+pct.toFixed(3)+'%;border-right:1px solid rgba(0,0,0,0.25)\" title=\"Other: '+fmt(residual)+' ('+pct.toFixed(1)+'%)\"></div>';}if(freeB>0){var pct=100*freeB/Math.max(sz,1);segs+='<div style=\"height:100%;background:'+FREE_COLOR+';width:'+pct.toFixed(3)+'%\" title=\"Free: '+fmt(freeB)+' ('+pct.toFixed(1)+'%)\"></div>';}var legend='';var pairs=CATS.map(function(x){return [x[2],x[1],c[x[0]]||0];});if(residual>0)pairs.push(['Other',OTHER_COLOR,residual]);if(freeB>0)pairs.push(['Free',FREE_COLOR,freeB]);pairs.sort(function(a,b){return b[2]-a[2];}).forEach(function(p){if(p[2]<=0)return;legend+='<span style=\"display:inline-flex;align-items:center;gap:5px;white-space:nowrap;margin-right:14px\"><span style=\"width:8px;height:8px;border-radius:50%;background:'+p[1]+';display:inline-block\"></span>'+esc(p[0])+' <em style=\"color:#888;font-style:normal;margin-left:2px\">'+fmt(p[2])+'</em></span>';});var marginTop=(node===lastNode)?'4px':'18px';var nodeLabel=(node===lastNode)?'<span style=\"color:#666\">\\u00a0</span>':'<strong>'+esc(node)+'</strong>';html+='<div style=\"margin-top:'+marginTop+'\"><div style=\"display:flex;justify-content:space-between;margin-bottom:6px;font-size:13px\"><span>'+nodeLabel+'<span style=\"color:#888;margin-left:8px;font-family:monospace;font-size:12px\">'+esc(mp)+'</span></span><span style=\"color:#aaa\">'+fmt(u)+' of '+fmt(sz)+' used <em style=\"color:#888;font-style:normal\">('+(sz?Math.round(100*u/sz):0)+'%)</em></span></div><div style=\"display:flex;height:22px;border-radius:5px;overflow:hidden;background:'+FREE_COLOR+';box-shadow:inset 0 0 0 1px rgba(255,255,255,0.05)\">'+segs+'</div><div style=\"display:flex;flex-wrap:wrap;gap:4px 0;margin-top:5px;font-size:11px;color:#ccc\">'+legend+'</div></div>';lastNode=node;});var disks=document.getElementById('ksdg-storage-disks');if(disks)disks.innerHTML=html;}function key(n,m){return n+'|'+m;}function load(){var t0=Date.now();return Promise.all([q(PREFIX+'_node_filesystem_size_bytes'),q(PREFIX+'_node_filesystem_used_bytes'),q(PREFIX+'_node_storage_bytes'),q('sum by (node, disk_path) (longhorn_replica_info * on(volume) group_left() longhorn_volume_actual_size_bytes)')]).then(function(arr){var size={},used={},cats={};function skipMP(m){return m.indexOf('/boot')===0;}arr[0].forEach(function(r){if(skipMP(r.metric.mountpoint))return;size[key(r.metric.node,r.metric.mountpoint)]=+r.value[1];});arr[1].forEach(function(r){if(skipMP(r.metric.mountpoint))return;used[key(r.metric.node,r.metric.mountpoint)]=+r.value[1];});function pickTargetForKubelet(n,m){var hasRoot=Object.prototype.hasOwnProperty.call(size,key(n,'/'));return hasRoot?'/':(function(){for(var k in size){var p=k.split('|');if(p[0]===n)return p[1];}return '/';})();}arr[2].forEach(function(r){var n=r.metric.node,mp=r.metric.mountpoint,c=r.metric.category;var target=(mp==='imageFs'||mp==='ephemeral')?pickTargetForKubelet(n,mp):mp;var k=key(n,target);if(!cats[k])cats[k]={};cats[k][c]=(cats[k][c]||0)+(+r.value[1]);});arr[3].forEach(function(r){var n=r.metric.node,v=+r.value[1];var dp=(r.metric.disk_path||'/').replace(/\\/+$/,'')||'/';var nMnts=[];for(var k in size){var p=k.split('|');if(p[0]===n)nMnts.push(p[1]);}var target='/',bestLen=-1;nMnts.forEach(function(m){if(dp===m||dp.indexOf(m==='/'?'/':m+'/')===0){if(m.length>bestLen){bestLen=m.length;target=m;}}});if(bestLen<0)target=nMnts.indexOf('/')!==-1?'/':(nMnts[0]||'/');var k=key(n,target);if(!cats[k])cats[k]={};cats[k]['longhorn']=(cats[k]['longhorn']||0)+v;});render(size,used,cats);loadCount++;var rEl=document.getElementById('ksdg-storage-refresh');if(rEl){var d=new Date();var hh=String(d.getHours()).padStart(2,'0'),mm=String(d.getMinutes()).padStart(2,'0'),ss=String(d.getSeconds()).padStart(2,'0');rEl.textContent='Last refresh: '+hh+':'+mm+':'+ss+' (#'+loadCount+', '+(Date.now()-t0)+'ms)';}}).catch(function(e){var s=document.getElementById('ksdg-storage-summary');if(s)s.textContent='render error: '+(e&&e.message?e.message:e);});}window.__KSDG_LOAD=load;load();if(window.__KSDG_TIMER)clearInterval(window.__KSDG_TIMER);window.__KSDG_TIMER=setInterval(load,60000);})();</script>"
      }
